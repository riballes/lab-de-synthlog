# Synthlog Configuration
# Copy to .env and fill in your values: cp .env.example .env

# API key for REST API authentication (required for `synthlog serve`)
SYNTHLOG_API_KEY=your-secret-api-key

# Generation defaults (all optional, these are the defaults)
SYNTHLOG_SEED=42
SYNTHLOG_NUM_USERS=5
SYNTHLOG_DURATION_HOURS=8
SYNTHLOG_EMITTER=jsonl
SYNTHLOG_OUTPUT_PATH=output/events.jsonl
SYNTHLOG_EVENTS_PER_USER_PER_HOUR=2.0

# API server
SYNTHLOG_HTTP_PORT=8080

# GCP (for Terraform / CI/CD)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
TF_STATE_BUCKET=your-tf-state-bucket
