# Copy to terraform.tfvars and fill in your values
project_id = "your-gcp-project-id"
region     = "us-central1"
image_tag  = "latest"

# Synthlog configuration
synthlog_seed           = 42
synthlog_users          = 5
synthlog_duration_hours = 8
synthlog_emitter        = "jsonl"
synthlog_scenarios      = "credential_stuffing"

# Cloud Scheduler (leave empty to disable)
# scheduler_cron     = "0 8 * * 1-5"  # 8 AM weekdays
# scheduler_timezone = "America/Los_Angeles"

# Resource limits
job_memory  = "512Mi"
job_cpu     = "1"
job_timeout = "3600s"
